{
  "entities": {
    "User": {
      "title": "用户",
      "description": "系统管理员账号信息",
      "type": "object",
      "properties": {
        "last_login_ip": { "type": "string", "description": "最后一次登录 IP" },
        "common_login_ips": { "type": "array", "description": "常用登录 IP 列表，登录次数达到阈值后写入" },
        "login_ip_stats": { "type": "array", "description": "登录 IP 统计，包含 ip、login_count、first_login_time、last_login_time" },
        "username": { "type": "string", "description": "登录账号" },
        "password": { "type": "string", "description": "MD5 加密后的密码" },
        "role": { "type": "string", "description": "用户角色标识" },
        "roleName": { "type": "string", "description": "用户角色名称" },
        "employeeNo": { "type": "string", "description": "工号" },
        "nickname": { "type": "string", "description": "用户昵称" },
        "avatarUrl": { "type": "string", "description": "用户头像访问地址" },
        "avatarFileId": { "type": "string", "description": "用户头像云存储文件 ID" },
        "lastLoginTime": { "type": "string", "description": "最后登录时间" },
        "updateTime": { "type": "string", "description": "最后更新时间" }
      },
      "required": ["username", "password"]
    },
    "Project": {
      "title": "项目",
      "description": "园林景观项目核心信息",
      "type": "object",
      "properties": {
        "clientId": { "type": "string", "description": "关联的客户 ID" },
        "name": { "type": "string", "description": "项目名称" },
        "scene": { "type": "string", "description": "项目场景标识（对应系统配置中的 PROJECT_SCENE）" },
        "sceneLabel": { "type": "string", "description": "项目场景名称（冗余显示）" },
        "client": { "type": "string", "description": "客户单位名称（冗余存储）" },
        "clientRole": { "type": "string", "description": "客户角色（冗余存储）" },
        "startDate": { "type": "string", "format": "date", "description": "项目开始日期" },
        "endDate": { "type": "string", "format": "date", "description": "项目结束日期" },
        "staffCount": { "type": "number", "description": "投入人员数量" },
        "totalAmount": { "type": "number", "description": "项目订单金额" },
        "receivedAmount": { "type": "number", "description": "已收账款金额" },
        "unreceivedAmount": { "type": "number", "description": "未收账款金额（自动计算）" },
        "payableAmount": { "type": "number", "description": "应付账款金额（自动计算）" },
        "paidAmount": { "type": "number", "description": "已付账款金额（自动计算）" },
        "description": { "type": "string", "description": "项目详细描述" },
        "statusCode": { "type": "string", "description": "项目状态标识（对应系统配置中的 PROJECT_STATUS）" },
        "statusLabel": { "type": "string", "description": "项目状态名称（冗余显示）" },
        "negotiatingTime": { "type": "string", "format": "date-time", "description": "进入洽谈状态的时间节点" },
        "constructingTime": { "type": "string", "format": "date-time", "description": "进入交付状态的时间节点" },
        "completedTime": { "type": "string", "format": "date-time", "description": "进入已交付状态的时间节点" },
        "settledTime": { "type": "string", "format": "date-time", "description": "进入结清状态的时间节点" },
        "isHasContract": { "type": "string", "description": "是否有合同（yes/no）", "enum": ["yes", "no"] },
        "isHasPreview": { "type": "string", "description": "是否有预览图（yes/no）", "enum": ["yes", "no"] },
        "isHasVoucher": { "type": "string", "description": "是否有发票凭证（yes/no）", "enum": ["yes", "no"] },
        "type": { "type": "string", "description": "项目类型（normal: 常规, historical: 补录, long_term: 长期）" },
        "completionTime": { "type": "string", "format": "date-time", "description": "补录单：完结时间" },
        "isHistorical": { "type": "boolean", "description": "是否为历史补录数据" },
        "constructionPeriod": { "type": "array", "description": "历史补录：施工周期日期范围" },
        "collectionPeriod": { "type": "array", "description": "历史补录：回款周期日期范围" },
        "amountEditCount": { "type": "number", "description": "订单金额修改次数（创建成功后最多允许修改一次）" },
        "createdAt": { "type": "string", "format": "date-time", "description": "创建时间" },
        "updatedAt": { "type": "string", "format": "date-time", "description": "最后更新时间" }
      },
      "required": ["name", "clientId", "totalAmount", "statusCode"]
    },
    "Client": {
      "title": "客户",
      "description": "客户管理信息",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "客户名称" },
        "role": { "type": "string", "description": "客户角色（冗余显示）" },
        "roleCode": { "type": "string", "description": "客户角色标识（对应系统配置中的 CLIENT_ROLE）" },
        "source": { "type": "string", "description": "客户来源" },
        "paymentCycle": { "type": "string", "description": "回款周期" },
        "description": { "type": "string", "description": "客户描述" },
        "createdAt": { "type": "string", "format": "date-time", "description": "创建时间" }
      },
      "required": ["name", "roleCode"]
    },
    "SystemConfig": {
      "title": "系统通用配置",
      "description": "统一管理下拉选项配置（角色、状态、类目等）",
      "type": "object",
      "properties": {
        "group": { "type": "string", "description": "配置分组，如 CLIENT_ROLE, PROJECT_STATUS, COST_CATEGORY, PROJECT_SCENE, SYSTEM_SETTING" },
        "label": { "type": "string", "description": "显示名称（如：项目经理）" },
        "value": { "type": "string", "description": "唯一标识/代码（如：pm）" },
        "sortOrder": { "type": "number", "description": "排序权重" },
        "isActive": { "type": "boolean", "description": "是否启用" },
        "description": { "type": "string", "description": "备注说明" },
        "createdAt": { "type": "string", "format": "date-time", "description": "创建时间" }
      },
      "required": ["group", "label", "value"]
    },
    "Cost": {
      "title": "成本项",
      "description": "项目的具体成本支出明细",
      "type": "object",
      "properties": {
        "projectId": { "type": "string", "description": "关联的项目 ID" },
        "categoryCode": { "type": "string", "description": "成本类目标识（对应系统配置中的 COST_CATEGORY）" },
        "categoryLabel": { "type": "string", "description": "成本类目名称（冗余显示）" },
        "supplier": { "type": "string", "description": "供应商名称" },
        "amount": { "type": "number", "description": "支出金额" },
        "isSettled": { "type": "boolean", "description": "是否已结清" },
        "createdAt": { "type": "string", "format": "date-time", "description": "记录时间" }
      },
      "required": ["projectId", "categoryCode", "amount"]
    },
    "Voucher": {
      "title": "凭证",
      "description": "项目相关的单据或图片凭证",
      "type": "object",
      "properties": {
        "projectId": { "type": "string", "description": "关联的项目 ID" },
        "url": { "type": "string", "description": "凭证图片在云存储中的 URL" },
        "name": { "type": "string", "description": "凭证名称或描述" },
        "createdAt": { "type": "string", "format": "date-time", "description": "上传时间" }
      },
      "required": ["projectId", "url"]
    },
    "Contract": {
      "title": "项目合同",
      "description": "项目相关的合同文件（图片或 PDF）",
      "type": "object",
      "properties": {
        "projectId": { "type": "string", "description": "关联的项目 ID" },
        "url": { "type": "string", "description": "文件在云存储中的 URL" },
        "fileId": { "type": "string", "description": "云存储文件 ID" },
        "name": { "type": "string", "description": "文件名称" },
        "type": { "type": "string", "description": "文件类型（image/pdf）" },
        "createdAt": { "type": "string", "format": "date-time", "description": "上传时间" }
      },
      "required": ["projectId", "url", "fileId"]
    },
    "PreviewImage": {
      "title": "项目预览图",
      "description": "项目效果预览图（仅限图片）",
      "type": "object",
      "properties": {
        "projectId": { "type": "string", "description": "关联的项目 ID" },
        "url": { "type": "string", "description": "图片在云存储中的 URL" },
        "fileId": { "type": "string", "description": "云存储文件 ID" },
        "createdAt": { "type": "string", "format": "date-time", "description": "上传时间" }
      },
      "required": ["projectId", "url", "fileId"]
    },
    "OperationLog": {
      "title": "操作日志",
      "description": "后台管理端关键操作审计记录",
      "type": "object",
      "properties": {
        "user_id": { "type": "string", "description": "操作用户 ID" },
        "username": { "type": "string", "description": "登录账号" },
        "nickname": { "type": "string", "description": "用户昵称" },
        "user_role": { "type": "string", "description": "用户角色标识" },
        "module": { "type": "string", "description": "操作所属模块" },
        "action": { "type": "string", "description": "操作动作，如 create/update/delete/view/export" },
        "content": { "type": "string", "description": "操作内容描述" },
        "status": { "type": "string", "description": "操作状态", "enum": ["成功", "警告", "失败"] },
        "ip": { "type": "string", "description": "客户端 IP" },
        "user_agent": { "type": "string", "description": "客户端 User-Agent" },
        "create_time": { "type": "string", "format": "date-time", "description": "操作时间 ISO 字符串" },
        "create_timestamp": { "type": "number", "description": "操作时间戳" },
        "createdAt": { "type": "string", "format": "date-time", "description": "记录创建时间" }
      },
      "required": ["user_id", "module", "content", "status", "create_timestamp"]
    }
  },
  "firestore": {
    "users": {
      "schema": { "$ref": "User" },
      "description": "管理员集合"
    },
    "projects": {
      "schema": { "$ref": "Project" },
      "description": "项目信息集合"
    },
    "clients": {
      "schema": { "$ref": "Client" },
      "description": "客户信息集合"
    },
    "system_configs": {
      "schema": { "$ref": "SystemConfig" },
      "description": "系统通用配置集合"
    },
    "costs": {
      "schema": { "$ref": "Cost" },
      "description": "成本明细集合"
    },
    "vouchers": {
      "schema": { "$ref": "Voucher" },
      "description": "项目凭证集合"
    },
    "project_contracts": {
      "schema": { "$ref": "Contract" },
      "description": "项目合同集合"
    },
    "project_previews": {
      "schema": { "$ref": "PreviewImage" },
      "description": "项目预览图集合"
    },
    "operation_logs": {
      "schema": { "$ref": "OperationLog" },
      "description": "操作日志集合"
    }
  }
}
