page {
  min-height: 100%;
  background: #f5f7f6;
  color: #1f2937;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", sans-serif;
  font-size: 28rpx;
}

view,
input,
button,
textarea {
  box-sizing: border-box;
}

button::after {
  border: 0;
}

.page {
  min-height: 100vh;
  padding: 28rpx;
}

.card {
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 8rpx 28rpx rgba(31, 41, 55, 0.06);
}

.primary-button {
  height: 88rpx;
  border-radius: 16rpx;
  background: #146c43;
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  line-height: 88rpx;
}

.primary-button[disabled] {
  background: #9bbdad;
  color: #fff;
}

.muted {
  color: #6b7280;
}