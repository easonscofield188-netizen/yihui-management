.tab-bar { position: relative; display: flex; box-sizing: border-box; height: calc(118rpx + env(safe-area-inset-bottom)); padding: 0 24rpx env(safe-area-inset-bottom); align-items: center; border-top: 2rpx solid #e7eeff; background: #fff; box-shadow: 0 -8rpx 24rpx rgba(26,54,93,.05); }
.tab-item,.create-item { display: flex; flex: 1; flex-direction: column; align-items: center; gap: 6rpx; color: #5b5f61; font-size: 22rpx; }
.tab-item { height: 88rpx; justify-content: center; }
.tab-pill { display: flex; min-width: 126rpx; padding: 10rpx 22rpx; flex-direction: column; align-items: center; justify-content: center; gap: 5rpx; border-radius: 999rpx; transition: background .18s ease, color .18s ease, transform .18s ease; }
.tab-item.selected { color: #adc7f7; font-weight: 700; }
.tab-item.selected .tab-pill { background: #1a365d; box-shadow: 0 6rpx 14rpx rgba(26,54,93,.16); }
.create-item { position: relative; align-self: stretch; justify-content: flex-end; padding-bottom: 12rpx; color: #43474e; }
.create-button { position: absolute; top: -56rpx; display: flex; width: 104rpx; height: 104rpx; align-items: center; justify-content: center; border: 8rpx solid #fff; border-radius: 50%; background: #002045; box-shadow: 0 8rpx 22rpx rgba(26,54,93,.2); }
