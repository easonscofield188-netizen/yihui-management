page { background: #f9f9ff; }
.projects-page { min-height: 100vh; padding-bottom: calc(220rpx + env(safe-area-inset-bottom)); background: #f9f9ff; color: #121c2c; }
.top-bar { position: sticky; top: 0; z-index: 10; box-sizing: border-box; display: flex; padding-right: 32rpx; padding-left: 32rpx; align-items: center; background: #fff; box-shadow: 0 2rpx 8rpx rgba(26,54,93,.03); }
.brand { display: flex; align-items: center; gap: 16rpx; color: #002045; font-size: 40rpx; font-weight: 700; }
.filter-panel { padding: 32rpx; border-bottom: 2rpx solid #e7eeff; background: rgba(255,255,255,.94); }
.search-box { display: flex; height: 88rpx; align-items: center; gap: 16rpx; padding: 0 28rpx; border-radius: 48rpx; background: #e7eeff; }
.search-input { flex: 1; height: 88rpx; color: #121c2c; font-size: 28rpx; }
.search-placeholder { color: #74777f; }
.status-tabs { display: flex; gap: 22rpx; margin-top: 28rpx; }
.status-tab { min-width: 132rpx; padding: 14rpx 22rpx; border: 2rpx solid #c4c6cf; border-radius: 42rpx; color: #43474e; font-size: 26rpx; line-height: 32rpx; text-align: center; }
.status-tab.active { border-color: #1a365d; background: #1a365d; color: #adc7f7; font-weight: 600; }
.query-loading-mask { position: fixed; z-index: 50; inset: 0; display: flex; align-items: center; justify-content: center; background: rgba(249,249,255,.78); }
.query-loading-content { display: flex; padding: 24rpx 34rpx; align-items: center; gap: 16rpx; border: 2rpx solid #e7eeff; border-radius: 18rpx; background: #fff; color: #002045; font-size: 25rpx; box-shadow: 0 10rpx 28rpx rgba(26,54,93,.1); }
.project-list { padding: 32rpx; }
.project-card { overflow: hidden; margin-bottom: 28rpx; border: 2rpx solid #d9e3f9; border-radius: 20rpx; background: #fff; box-shadow: 0 8rpx 24rpx rgba(26,54,93,.04); }
.card-accent { height: 7rpx; background: #d6e3ff; }
.closed-card { opacity: .82; }
.closed-card .card-accent { background: #c1c7cf; }
.card-body { padding: 28rpx 32rpx 32rpx; }
.project-meta { display: flex; align-items: center; justify-content: space-between; gap: 12rpx; }
.project-code { color: #74777f; font-size: 26rpx; font-weight: 600; letter-spacing: 1rpx; }
.status-badge { display: flex; flex-shrink: 0; align-items: center; gap: 8rpx; padding: 8rpx 18rpx; border-radius: 32rpx; background: #e7eeff; color: #002045; font-size: 23rpx; }
.status-dot { width: 10rpx; height: 10rpx; border-radius: 50%; background: #002045; }
.status-closed { background: #e7eeff; color: #43474e; }
.project-name { margin-top: 24rpx; overflow: hidden; color: #121c2c; font-size: 34rpx; font-weight: 700; line-height: 48rpx; text-overflow: ellipsis; white-space: nowrap; }
.client-row { display: flex; align-items: center; gap: 10rpx; margin-top: 12rpx; color: #43474e; font-size: 27rpx; line-height: 38rpx; }
.delivery-row { display: flex; align-items: center; gap: 10rpx; margin-top: 12rpx; color: #74777f; font-size: 24rpx; line-height: 36rpx; }
.delivery-date { margin-left: auto; color: #43474e; font-weight: 600; }
.divider { height: 2rpx; margin: 28rpx 0; background: #d9e3f9; }
.amount-main { display: flex; align-items: center; justify-content: space-between; padding: 22rpx 24rpx; border: 2rpx solid #d9e3f9; border-radius: 14rpx; background: #f0f3ff; color: #43474e; font-size: 28rpx; }
.amount-main-value { color: #121c2c; font-size: 34rpx; font-weight: 700; }
.amount-grid { display: grid; grid-template-columns: repeat(2, minmax(0,1fr)); gap: 22rpx; margin-top: 22rpx; }
.amount-cell { min-height: 130rpx; padding: 20rpx 24rpx; border: 2rpx solid #d9e3f9; border-radius: 14rpx; background: #fff; }
.amount-cell.receivable { border-color: #ffdad6; background: #fff8f7; }
.amount-cell.cost { background: #e7eeff; }
.amount-cell.profit { display: flex; min-height: 92rpx; grid-column: 1 / -1; align-items: center; justify-content: space-between; border-color: #cdebd9; background: linear-gradient(135deg, #f3fbf6, #eaf7ef); }
.amount-label { display: flex; align-items: center; gap: 8rpx; color: #43474e; font-size: 23rpx; }
.amount-value { display: block; margin-top: 14rpx; color: #43474e; font-size: 31rpx; font-weight: 700; }
.receivable .amount-value { color: #ba1a1a; }
.profit .amount-value { margin-top: 0; }
.profit-positive { color: #137047 !important; }
.profit-negative { color: #ba1a1a !important; }
.empty { padding: 140rpx 0; color: #74777f; font-size: 26rpx; text-align: center; }
.empty-title { margin-top: 20rpx; margin-bottom: 10rpx; color: #43474e; font-size: 30rpx; font-weight: 600; }
.loading { display: flex; align-items: center; justify-content: center; gap: 14rpx; padding: 26rpx; color: #989fa6; font-size: 24rpx; }
