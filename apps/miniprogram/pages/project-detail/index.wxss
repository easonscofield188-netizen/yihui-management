page {
  background: #f9f9ff;
}

.detail-nav {
  position: fixed;
  top: 0;
  right: 0;
  left: 0;
  z-index: 10;
  box-sizing: border-box;
  display: flex;
  width: 100%;
  align-items: center;
  border-bottom: 2rpx solid #f0f3ff;
  background: #ffffff;
}

.detail-nav-placeholder {
  width: 100%;
}

.nav-back {
  position: absolute;
  bottom: 0;
  left: 30rpx;
  display: flex;
  width: 70rpx;
  height: 88rpx;
  align-items: center;
  justify-content: flex-start;
}

.nav-title {
  position: absolute;
  right: 150rpx;
  bottom: 0;
  left: 150rpx;
  height: 88rpx;
  color: #002045;
  font-size: 40rpx;
  font-weight: 700;
  line-height: 88rpx;
  text-align: center;
}

.detail-page {
  min-height: 100vh;
  padding: 28rpx 32rpx 72rpx;
  color: #121c2c;
}

.project-heading {
  position: relative;
  margin-bottom: 24rpx;
  overflow: hidden;
  padding: 24rpx 28rpx;
  border: 2rpx solid rgba(214, 227, 255, .8);
  border-radius: 24rpx;
  background: linear-gradient(135deg, #ffffff 0%, #f2f6ff 100%);
  box-shadow:
    0 12rpx 30rpx rgba(26, 54, 93, .08),
    inset 0 2rpx 0 rgba(255, 255, 255, .95);
}

.project-heading::after {
  position: absolute;
  top: -54rpx;
  right: -42rpx;
  width: 170rpx;
  height: 170rpx;
  border-radius: 50%;
  background: rgba(214, 227, 255, .48);
  content: "";
}

.project-name {
  position: relative;
  z-index: 1;
  color: #002045;
  font-size: 46rpx;
  font-weight: 700;
  line-height: 58rpx;
  text-shadow: 0 2rpx 2rpx rgba(0, 32, 69, .05);
}

.status {
  position: relative;
  z-index: 1;
  display: inline-flex;
  align-items: center;
  gap: 9rpx;
  margin-top: 8rpx;
  padding: 5rpx 14rpx;
  border-radius: 999rpx;
  background: #e8f5e9;
  color: #2e7d32;
  font-size: 21rpx;
}

.status-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: currentColor;
}

.status-closed,
.status-terminated {
  background: #e7eeff;
  color: #455f88;
}

.finance-card {
  position: relative;
  overflow: hidden;
  padding: 46rpx 36rpx 36rpx;
  border: 2rpx solid rgba(134, 160, 205, .3);
  border-radius: 32rpx;
  background: linear-gradient(145deg, #001b3c 0%, #0b3566 55%, #174b7d 100%);
  color: #fff;
  box-shadow:
    0 26rpx 52rpx rgba(0, 32, 69, .22),
    0 8rpx 18rpx rgba(0, 32, 69, .16),
    inset 0 2rpx 0 rgba(255, 255, 255, .12);
}

.finance-glow {
  position: absolute;
  border-radius: 50%;
  pointer-events: none;
}

.finance-glow-top {
  top: -180rpx;
  right: -120rpx;
  width: 430rpx;
  height: 430rpx;
  background: radial-gradient(circle, rgba(86, 146, 208, .28) 0%, rgba(86, 146, 208, 0) 70%);
}

.finance-glow-bottom {
  bottom: -230rpx;
  left: -160rpx;
  width: 480rpx;
  height: 480rpx;
  background: radial-gradient(circle, rgba(69, 114, 172, .22) 0%, rgba(69, 114, 172, 0) 72%);
}

.finance-label,
.finance-sub-label,
.profit-label {
  position: relative;
  z-index: 1;
  color: rgba(255, 255, 255, .7);
  font-size: 22rpx;
}

.order-amount {
  position: relative;
  z-index: 1;
  margin-top: 8rpx;
  font-size: 68rpx;
  font-weight: 700;
  letter-spacing: -1rpx;
  text-shadow: 0 7rpx 16rpx rgba(0, 0, 0, .22);
}

.finance-columns {
  position: relative;
  z-index: 1;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 30rpx;
  margin-top: 46rpx;
}

.finance-column {
  padding: 18rpx 20rpx;
  border: 2rpx solid rgba(255, 255, 255, .08);
  border-radius: 16rpx;
  background: linear-gradient(135deg, rgba(255, 255, 255, .075), rgba(255, 255, 255, .025));
  box-shadow: inset 0 2rpx 0 rgba(255, 255, 255, .06);
}

.pending-column {
  border-color: rgba(255, 209, 102, .32);
  background: linear-gradient(135deg, rgba(255, 190, 66, .18), rgba(255, 148, 48, .08));
  box-shadow:
    0 8rpx 18rpx rgba(255, 157, 46, .1),
    inset 0 2rpx 0 rgba(255, 225, 157, .1);
}

.pending-column .finance-sub-label {
  color: #ffe09a;
}

.pending-column .finance-sub-value {
  color: #ffd166;
  text-shadow: 0 4rpx 12rpx rgba(255, 160, 32, .24);
}

.finance-sub-label {
  display: flex;
  align-items: center;
  gap: 9rpx;
}

.finance-sub-value {
  margin-top: 10rpx;
  font-size: 34rpx;
  font-weight: 700;
}

.profit-panel {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 34rpx;
  padding: 25rpx 28rpx;
  border: 2rpx solid rgba(255, 255, 255, .14);
  border-radius: 20rpx;
  background: linear-gradient(135deg, rgba(255, 255, 255, .14), rgba(255, 255, 255, .08));
  box-shadow:
    0 10rpx 22rpx rgba(0, 16, 40, .18),
    inset 0 2rpx 0 rgba(255, 255, 255, .08);
}

.profit-value {
  margin-top: 6rpx;
  color: #55e391;
  font-size: 40rpx;
  font-weight: 700;
}

.profit-negative {
  color: #ffb4ab;
}

.profit-icon {
  display: flex;
  width: 72rpx;
  height: 72rpx;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(85, 227, 145, .16);
  color: #55e391;
  font-size: 38rpx;
  font-weight: 700;
  box-shadow:
    0 8rpx 18rpx rgba(44, 190, 111, .16),
    inset 0 0 0 2rpx rgba(85, 227, 145, .12);
}

.detail-card {
  margin-top: 24rpx;
  padding: 32rpx;
  border: 2rpx solid rgba(214, 227, 255, .62);
  border-radius: 32rpx;
  background: linear-gradient(180deg, #ffffff 0%, #fefeff 100%);
  box-shadow:
    0 18rpx 42rpx rgba(26, 54, 93, .09),
    0 4rpx 12rpx rgba(26, 54, 93, .05),
    inset 0 2rpx 0 rgba(255, 255, 255, .9);
}

.card-header,
.card-heading,
.info-row,
.cost-item {
  display: flex;
  align-items: center;
}

.card-header,
.info-row,
.cost-item {
  justify-content: space-between;
}

.card-heading {
  gap: 18rpx;
}

.heading-icon {
  display: flex;
  width: 68rpx;
  height: 68rpx;
  align-items: center;
  justify-content: center;
  border-radius: 18rpx;
  font-size: 30rpx;
  font-weight: 700;
  box-shadow: 0 6rpx 14rpx rgba(26, 54, 93, .09);
}

.customer-icon {
  background: #edf4ff;
  color: #002045;
}

.cost-icon {
  background: #fff5eb;
  color: #a84f00;
}

.voucher-icon {
  background: #f7edff;
  color: #76508e;
}

.card-title {
  font-size: 32rpx;
  font-weight: 700;
}

.info-list {
  margin-top: 24rpx;
}

.info-row {
  min-height: 64rpx;
  border-bottom: 2rpx solid #eef1f7;
  color: #5f6365;
  font-size: 26rpx;
}

.info-value {
  max-width: 62%;
  color: #121c2c;
  text-align: right;
}

.strong {
  font-weight: 700;
}

.role-badge {
  padding: 5rpx 14rpx;
  border-radius: 6rpx;
  background: #e7eeff;
  color: #002045;
  font-size: 21rpx;
  font-weight: 600;
}

.cost-total {
  color: #74777f;
  text-align: right;
  font-size: 17rpx;
}

.cost-total text {
  display: block;
  margin-top: 4rpx;
  color: #ba1a1a;
  font-size: 26rpx;
  font-weight: 700;
}

.cost-item {
  margin-top: 24rpx;
  padding: 20rpx 22rpx;
  border: 2rpx solid rgba(217, 227, 249, .75);
  border-radius: 18rpx;
  background: #ffffff;
  box-shadow:
    0 8rpx 18rpx rgba(26, 54, 93, .055),
    inset 0 2rpx 0 rgba(255, 255, 255, .95);
}

.cost-symbol {
  display: flex;
  width: 72rpx;
  height: 72rpx;
  flex: none;
  align-items: center;
  justify-content: center;
  border: 2rpx solid #eef0f3;
  border-radius: 50%;
  background: #f9fafc;
  color: #002045;
}

.cost-info {
  min-width: 0;
  margin-left: 18rpx;
  flex: 1;
}

.cost-name {
  overflow: hidden;
  color: #121c2c;
  font-size: 26rpx;
  font-weight: 700;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.cost-category {
  margin-top: 6rpx;
  color: #74777f;
  font-size: 20rpx;
}

.cost-right {
  margin-left: 14rpx;
  text-align: right;
}

.cost-amount {
  font-size: 25rpx;
  font-weight: 700;
}

.settled {
  display: inline-block;
  margin-top: 6rpx;
  padding: 3rpx 9rpx;
  border-radius: 5rpx;
  background: #fff0e6;
  color: #b54708;
  font-size: 17rpx;
}

.settled.yes {
  background: #eef0f3;
  color: #5f6365;
}

.voucher-count {
  color: #74777f;
  font-size: 22rpx;
}

.voucher-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
  margin-top: 24rpx;
}

.voucher-item {
  position: relative;
  width: 100%;
  height: 190rpx;
  overflow: hidden;
  border-radius: 16rpx;
  box-shadow: 0 8rpx 18rpx rgba(26, 54, 93, .1);
}

.voucher-image {
  width: 100%;
  height: 100%;
}

.pdf-voucher {
  display: flex;
  height: 100%;
  align-items: center;
  justify-content: center;
  background: #f0f3ff;
  color: #ba1a1a;
  font-size: 26rpx;
  font-weight: 700;
}

.description {
  margin-top: 20rpx;
  color: #5f6365;
  font-size: 25rpx;
  line-height: 1.7;
}

.empty-row {
  padding: 36rpx 0 10rpx;
  color: #989fa6;
  text-align: center;
  font-size: 23rpx;
}

.detail-loading-mask {
  position: fixed;
  z-index: 50;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(249, 249, 255, .78);
}

.detail-loading-content {
  display: flex;
  padding: 24rpx 34rpx;
  align-items: center;
  gap: 16rpx;
  border: 2rpx solid #e7eeff;
  border-radius: 18rpx;
  background: #ffffff;
  color: #002045;
  font-size: 25rpx;
  box-shadow: 0 10rpx 28rpx rgba(26, 54, 93, .1);
}

.overlay {
  position: fixed;
  z-index: 20;
  inset: 0;
  display: flex;
  align-items: flex-end;
  background: rgba(15, 23, 18, .48);
}

.form-sheet {
  box-sizing: border-box;
  width: 100%;
  max-height: 78vh;
  overflow-y: auto;
  padding: 34rpx 34rpx calc(32rpx + env(safe-area-inset-bottom));
  border-radius: 30rpx 30rpx 0 0;
  background: #fff;
  transition: transform .18s ease, max-height .18s ease;
}

.sheet-title {
  margin-bottom: 34rpx;
  color: #002045;
  font-size: 36rpx;
  font-weight: 700;
}

.field-label {
  margin: 26rpx 0 12rpx;
  color: #526058;
  font-size: 24rpx;
  font-weight: 600;
}

.amount-input-wrap,
.text-input,
.picker-field {
  box-sizing: border-box;
  height: 84rpx;
  border: 2rpx solid #d9e0e7;
  border-radius: 14rpx;
  background: #fafcff;
}

.amount-input-wrap {
  display: flex;
  align-items: center;
  padding: 0 22rpx;
  font-size: 34rpx;
}

.amount-input {
  height: 100%;
  margin-left: 14rpx;
  flex: 1;
  font-size: 34rpx;
}

.text-input,
.picker-field {
  padding: 0 22rpx;
  line-height: 84rpx;
}

.switch-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 30rpx;
  padding: 20rpx 0;
}

.switch-title {
  font-weight: 600;
}

.switch-tip {
  margin-top: 5rpx;
  color: #74777f;
  font-size: 22rpx;
}

.submit-button {
  margin-top: 30rpx;
  background: #002045;
}

.cancel-button {
  height: 76rpx;
  margin-top: 14rpx;
  background: transparent;
  color: #66736c;
  font-size: 26rpx;
  line-height: 76rpx;
}
