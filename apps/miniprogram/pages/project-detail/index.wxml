<view class="detail-nav" style="height: {{navHeight}}px; padding-top: {{statusBarHeight}}px;">
  <view class="nav-back" bindtap="goBack">
    <t-icon name="chevron-left" size="48rpx" color="#002045" />
  </view>
  <view class="nav-title">项目详情</view>
</view>
<view class="detail-nav-placeholder" style="height: {{navHeight}}px;"></view>

<view class="detail-page" wx:if="{{project}}">
  <view class="project-heading">
    <view class="project-name">{{project.name}}</view>
    <view class="status status-{{project.status}}">
      <view class="status-dot"></view>
      <text>{{project.statusLabel}}</text>
    </view>
  </view>

  <view class="finance-card">
    <view class="finance-glow finance-glow-top"></view>
    <view class="finance-glow finance-glow-bottom"></view>
    <view class="finance-label">订单总金额</view>
    <view class="order-amount">¥{{project.amountText}}</view>

    <view class="finance-columns">
      <view class="finance-column">
        <view class="finance-sub-label"><t-icon name="wallet" size="26rpx" color="rgba(255,255,255,.7)" />已收金额</view>
        <view class="finance-sub-value">¥{{project.receivedText}}</view>
      </view>
      <view class="finance-column pending-column">
        <view class="finance-sub-label"><t-icon name="time" size="26rpx" color="#ffd166" />待收金额</view>
        <view class="finance-sub-value">¥{{project.unreceivedText}}</view>
      </view>
    </view>

    <view class="profit-panel">
      <view>
        <view class="profit-label">项目利润</view>
        <view class="profit-value {{project.profitPositive ? '' : 'profit-negative'}}">¥{{project.profitText}}</view>
      </view>
      <view class="profit-icon"><t-icon name="chart-line" size="38rpx" color="#55e391" /></view>
    </view>
  </view>

  <view class="detail-card customer-card">
    <view class="card-header">
      <view class="card-heading">
        <view class="heading-icon customer-icon"><t-icon name="user" size="34rpx" color="#002045" /></view>
        <view class="card-title">基础信息</view>
      </view>
    </view>
    <view class="info-list">
      <view class="info-row"><text>客户名称</text><text class="info-value strong">{{project.client || '未填写'}}</text></view>
      <view class="info-row"><text>角色</text><text class="role-badge">{{project.roleText}}</text></view>
      <view class="info-row"><text>来源</text><text class="info-value">{{project.sourceText}}</text></view>
      <view class="info-row"><text>项目场景</text><text class="info-value">{{project.sceneText}}</text></view>
      <view class="info-row"><text>人员数量</text><text class="info-value">{{project.staffCountText}} 人</text></view>
      <view class="info-row"><text>交付时间</text><text class="info-value">{{project.deliveryDateText}}</text></view>
    </view>
  </view>

  <view class="detail-card cost-card">
    <view class="card-header">
      <view class="card-heading">
        <view class="heading-icon cost-icon"><t-icon name="bill" size="36rpx" color="#002045" /></view>
        <view class="card-title">成本支出</view>
      </view>
      <view class="cost-total">
        <view>总预计成本</view>
        <text>¥{{project.payableText}}</text>
      </view>
    </view>
    <view class="cost-item" wx:for="{{project.costs}}" wx:key="id">
      <view class="cost-symbol"><t-icon name="vehicle" size="34rpx" color="#002045" /></view>
      <view class="cost-info">
        <view class="cost-name">{{item.displayName}}</view>
        <view class="cost-category">{{item.subText}}</view>
      </view>
      <view class="cost-right">
        <view class="cost-amount">¥{{item.amountText}}</view>
        <view class="settled {{item.settled ? 'yes' : ''}}">
          {{item.settled ? '已支付' : '待支付'}}
        </view>
      </view>
    </view>
    <view class="empty-row" wx:if="{{!project.costs.length}}">暂无成本记录</view>
  </view>

  <view class="detail-card voucher-card">
    <view class="card-header">
      <view class="card-heading">
        <view class="heading-icon voucher-icon"><t-icon name="bill" size="36rpx" color="#8e43c7" /></view>
        <view class="card-title">项目凭证</view>
      </view>
    </view>
    <view class="voucher-grid">
      <view class="voucher-item" wx:for="{{vouchers}}" wx:key="_id">
        <image
          wx:if="{{item.isImage !== false}}"
          class="voucher-image"
          src="{{item.displayUrl || item.fileUrl}}"
          mode="aspectFill"
          data-url="{{item.displayUrl || item.fileUrl}}"
          bindtap="previewVoucher"
        />
        <view wx:else class="pdf-voucher">PDF</view>
      </view>
    </view>
    <view class="empty-row" wx:if="{{!vouchers.length}}">暂无凭证</view>
  </view>

</view>

<view class="detail-loading-mask" wx:if="{{loading}}" catchtap="stopPropagation" catchtouchmove="stopPropagation">
  <view class="detail-loading-content">
    <t-loading size="44rpx" theme="circular" />
    <text>正在加载项目详情...</text>
  </view>
</view>

<view class="overlay" wx:if="{{formMode}}" bindtap="closeForm">
  <view
    class="form-sheet"
    style="transform: translateY(-{{keyboardHeight}}px); max-height: {{keyboardHeight > 0 ? (windowHeight - keyboardHeight - 16) : (windowHeight * 0.78)}}px;"
    catchtap="stopPropagation"
  >
    <view class="sheet-title">{{formMode === 'receipt' ? '登记收款' : '登记支出'}}</view>
    <view class="field-label">本次金额</view>
    <view class="amount-input-wrap">
      <text>¥</text>
      <input
        class="amount-input"
        type="digit"
        placeholder="0.00"
        value="{{amountInput}}"
        adjust-position="{{false}}"
        cursor-spacing="160"
        bindinput="onAmountInput"
      />
    </view>

    <block wx:if="{{formMode === 'cost'}}">
      <view class="field-label">成本类别</view>
      <picker mode="selector" range="{{categories}}" value="{{categoryIndex}}" bindchange="onCategoryChange">
        <view class="picker-field">{{categories[categoryIndex]}}⌄</view>
      </picker>
      <view class="field-label">供应商</view>
      <input
        class="text-input"
        placeholder="选填，默认为无"
        value="{{supplierInput}}"
        adjust-position="{{false}}"
        cursor-spacing="120"
        bindinput="onSupplierInput"
      />
      <view class="switch-row">
        <view>
          <view class="switch-title">已支付</view>
          <view class="muted switch-tip">开启后计入已付成本</view>
        </view>
        <switch color="#146C43" checked="{{settled}}" bindchange="onSettledChange" />
      </view>
    </block>

    <button class="primary-button submit-button" loading="{{submitting}}" disabled="{{submitting}}" bindtap="submitRecord">
      确认提交
    </button>
    <button class="cancel-button" disabled="{{submitting}}" bindtap="closeForm">取消</button>
  </view>
</view>
