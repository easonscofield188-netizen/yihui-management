page { background: #f9f9ff; }.step4-page { --td-brand-color: #1a365d; display: flex; height: 100vh; overflow: hidden; flex-direction: column; background: #f9f9ff; color: #121c2c; }.step4-nav { position: relative; display: flex; box-sizing: border-box; flex: none; align-items: center; justify-content: center; border-bottom: 2rpx solid #f0f3ff; background: #f9f9ff; }.nav-close { position: absolute; bottom: 0; left: 30rpx; display: flex; width: 80rpx; height: 88rpx; align-items: center; justify-content: flex-start; }.nav-title { color: #002045; font-size: 42rpx; font-weight: 700; }.step4-scroll { box-sizing: border-box; width: 100%; height: 0; min-height: 0; padding: 38rpx 30rpx 44rpx; flex: 1; }.progress-section { margin-bottom: 56rpx; }.progress-text { display: flex; align-items: center; justify-content: space-between; color: #343943; font-size: 28rpx; }.progress-percent { color: #002045; font-size: 26rpx; font-weight: 700; }.progress { height: 14rpx; margin-top: 24rpx; overflow: hidden; border-radius: 14rpx; background: #e7eeff; }.progress-current { width: 100%; height: 100%; background: #1a365d; }.page-title { margin-bottom: 40rpx; color: #002045; font-size: 48rpx; font-weight: 700; }
.invoice-card { padding: 30rpx; border-radius: 26rpx; background: #fff; box-shadow: 0 8rpx 28rpx rgba(26,54,93,.045); }.invoice-head { display: flex; align-items: center; justify-content: space-between; }.invoice-title { color: #002045; font-size: 32rpx; font-weight: 700; }.invoice-hint { margin-top: 4rpx; color: #5f6365; font-size: 23rpx; }.upload-area { margin-top: 28rpx; }.upload-disabled { opacity: .35; }.file-grid { display: flex; flex-wrap: wrap; gap: 18rpx; }.file-item, .file-add { position: relative; box-sizing: border-box; width: calc((100% - 36rpx) / 3); height: 156rpx; overflow: hidden; border-radius: 14rpx; background: #f0f3ff; }.file-image { width: 100%; height: 100%; }.pdf-file, .file-add { display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 8rpx; }.pdf-file { height: 100%; color: #ba1a1a; font-size: 22rpx; }.file-add { border: 2rpx dashed #aeb5c2; background: #fff; color: #43474e; font-size: 21rpx; }.remove-file { position: absolute; top: 6rpx; right: 6rpx; display: flex; }.upload-note { display: flex; margin-top: 24rpx; align-items: center; gap: 8rpx; color: #5f6365; font-size: 21rpx; }.info-grid { display: flex; gap: 20rpx; margin-top: 40rpx; }.info-card { box-sizing: border-box; width: 50%; padding: 26rpx; border: 2rpx solid #cbd9f4; border-radius: 16rpx; background: #e7eeff; }.info-label { margin-top: 24rpx; color: #002045; font-size: 23rpx; font-weight: 700; }.info-value { margin-top: 8rpx; color: #343943; font-size: 22rpx; }.wizard-footer { position: relative; z-index: 8; display: flex; box-sizing: border-box; width: 100%; height: calc(142rpx + env(safe-area-inset-bottom)); padding: 18rpx 30rpx calc(18rpx + env(safe-area-inset-bottom)); flex: none; align-items: center; justify-content: space-between; border-top: 2rpx solid #f0f3ff; background: rgba(249,249,255,.98); }.footer-text-button { width: 130rpx; color: #43474e; font-size: 22rpx; }.disabled-button { color: #989fa6; }.submit-button { width: 140rpx; height: 100rpx !important; margin: 0; border-radius: 20rpx !important; background: #1a365d !important; color: #fff; font-size: 28rpx !important; font-weight: 600; }

/* 分步表单底部操作区 */
.wizard-footer { justify-content: center; gap: 18rpx; }
.footer-text-button {
  width: 170rpx;
  height: 92rpx !important;
