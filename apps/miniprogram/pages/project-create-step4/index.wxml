<view class="step4-page">
  <view class="step4-nav" style="height: {{navHeight}}px; padding-top: {{statusBarHeight}}px;"><view class="nav-close" bindtap="close"><t-icon name="close" size="44rpx" color="#002045" /></view><view class="nav-title">新建项目</view></view>
  <scroll-view class="step4-scroll" scroll-y show-scrollbar="{{false}}">
    <view class="progress-section"><view class="progress-text"><text>步骤 4 / 4</text><text class="progress-percent">已完成 100%</text></view><view class="progress"><view class="progress-current"></view></view></view>
    <view class="page-title">凭证附件</view>
    <view class="invoice-card"><view class="invoice-head"><view><view class="invoice-title">是否有发票？</view><view class="invoice-hint">通过文档核实项目支出</view></view><t-switch value="{{invoiceEnabled}}" bindchange="onInvoiceChange" /></view><view class="upload-area {{invoiceEnabled ? '' : 'upload-disabled'}}" wx:if="{{invoiceEnabled}}"><view class="file-grid"><view class="file-item" wx:for="{{files}}" wx:key="id"><image wx:if="{{item.isImage}}" class="file-image" src="{{item.tempFilePath}}" mode="aspectFill" data-path="{{item.tempFilePath}}" bindtap="previewFile" /><view wx:else class="pdf-file"><t-icon name="file-pdf" size="56rpx" color="#ba1a1a" /><text>PDF</text></view><view class="remove-file" data-id="{{item.id}}" bindtap="removeFile"><t-icon name="close-circle-filled" size="30rpx" color="#ffffff" /></view></view><view class="file-add" bindtap="chooseFile"><t-icon name="camera" size="46rpx" color="#002045" /><text>添加文件</text></view><view wx:for="{{[1,2,3,4,5,6,7,8,9]}}" wx:key="*this" wx:if="{{files.length + 1 < 10}}" class="file-placeholder"></view></view><view class="upload-note"><t-icon name="info-circle" size="26rpx" color="#5f6365" /><text>支持格式：JPG、PNG、PDF（最大 10MB）</text></view></view></view>
    <view class="info-grid"><view class="info-card"><t-icon name="error-circle" size="48rpx" color="#002045" /><view class="info-label">优先级</view><view class="info-value">高 - 关键资产</view></view><view class="info-card"><t-icon name="catalog" size="48rpx" color="#002045" /><view class="info-label">部门</view><view class="info-value">财务与运营</view></view></view>
  </scroll-view>
  <view class="wizard-footer"><t-button t-class="footer-text-button" theme="default" variant="text" icon="arrow-left" content="上一步" bindtap="previous" /><t-button t-class="footer-text-button disabled-button" theme="default" variant="text" icon="arrow-right" content="下一步" disabled /><t-button t-class="submit-button" theme="primary" icon="check-circle-filled" content="提交" loading="{{submitting}}" bindtap="submit" /></view>
</view>
