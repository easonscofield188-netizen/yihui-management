<view class="profile-page">
  <view class="profile-nav" style="height: {{navHeight}}px; padding-top: {{statusBarHeight}}px;">
    <view class="nav-wallet"><t-icon name="wallet" size="40rpx" color="#002045" /></view>
    <view class="nav-title">亿辉记</view>
  </view>

  <view class="profile-content" wx:if="{{userInfo}}">
    <view class="user-card">
      <view class="user-card-glow"></view>
      <view class="avatar-wrap">
        <image wx:if="{{userInfo.hasCustomAvatar}}" class="avatar-image" src="{{userInfo.avatarDisplayUrl}}" mode="aspectFill" binderror="onAvatarError" />
        <image wx:else class="avatar-image" src="../../images/default-user-avatar.png" mode="aspectFill" />
      </view>
      <view class="user-main">
        <view class="user-name">{{userInfo.displayName}}</view>
        <view class="role-badge">
          <t-icon name="check-circle" size="24rpx" color="#002045" />
          <text>{{userInfo.roleDisplayName}}</text>
        </view>
        <view class="employee-no">工号: {{userInfo.employeeDisplayNo}}</view>
      </view>
    </view>

    <view class="function-card">
      <view class="function-row" bindtap="openSecurity">
        <view class="function-main">
          <view class="function-icon"><t-icon name="lock-on" size="38rpx" color="#002045" /></view>
          <text>账号安全</text>
        </view>
        <t-icon name="chevron-right" size="38rpx" color="#74777f" />
      </view>
      <view class="function-divider"></view>
      <view class="function-row" bindtap="openProjects">
        <view class="function-main">
          <view class="function-icon"><t-icon name="catalog" size="38rpx" color="#002045" /></view>
          <text>项目总览</text>
        </view>
        <t-icon name="chevron-right" size="38rpx" color="#74777f" />
      </view>
      <block wx:if="{{userInfo.role === 'ADMIN_SUPER'}}">
        <view class="function-divider"></view>
        <view class="function-row" bindtap="openCreateAccount">
          <view class="function-main">
            <view class="function-icon"><t-icon name="user-add" size="38rpx" color="#002045" /></view>
            <text>创建账号</text>
          </view>
          <t-icon name="chevron-right" size="38rpx" color="#74777f" />
        </view>
      </block>
    </view>

    <button class="logout-button" bindtap="logout">
      <t-icon name="logout" size="34rpx" color="#ba1a1a" />
      <text>退出登录</text>
    </button>
  </view>

  <view class="profile-loading-mask" wx:if="{{loading}}" catchtap="stopPropagation" catchtouchmove="stopPropagation">
    <view class="profile-loading-content">
      <t-loading size="44rpx" theme="circular" />
      <text>{{loadingMessage}}</text>
    </view>
  </view>
</view>
